# MachineFit — copy to backend/.env and frontend/.env as needed

# Backend
NODE_ENV=development
PORT=3001
API_BASE_PATH=/api/v1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/machinefit

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public API base (used for local-upload media URLs when Supabase Storage is unset)
# PUBLIC_API_BASE_URL=https://machinefit-api.onrender.com/api/v1

# Motivation audio uploads (bytes / max tracks / storage bucket)
MOTIVATION_AUDIO_MAX_BYTES=20971520
MOTIVATION_AUDIO_MAX_TRACKS=20
MOTIVATION_AUDIO_BUCKET=motivation-audio

# Muscle group representative images (bytes / storage bucket)
MUSCLE_GROUP_IMAGE_MAX_BYTES=10485760
MUSCLE_GROUP_IMAGE_BUCKET=muscle-group-images

# CORS
CORS_ORIGIN=http://localhost:5173

# Email (Gmail 앱 비밀번호 또는 Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=MachineFit <your@gmail.com>
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=MachineFit <onboarding@resend.dev>
# FORMSUBMIT_ORIGIN=https://madbandi-star.github.io
# FORMSUBMIT_FALLBACK=false
# EMAIL_BROWSER_FALLBACK=true

# Frontend
VITE_API_BASE_URL=http://localhost:3001/api/v1
